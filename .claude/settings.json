{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Write(output/**)",
      "Write(references/cases/**)",
      "Edit(output/**)",
      "Edit(references/cases/**)",
      "Write(.claude/user-profile.md)",
      "Edit(.claude/user-profile.md)",
      "Bash(node ~/mission-control/cli.js*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/enforce-stage-prompt-load.sh\""
          }
        ]
      }
    ]
  }
}
